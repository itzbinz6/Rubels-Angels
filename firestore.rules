rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reviews: anyone can submit one (always lands as "pending"),
    // anyone can read approved ones, only a logged-in admin can read
    // pending ones, approve them, or delete them.
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || request.auth != null;

      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 80
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 20
                    && request.resource.data.text.size() < 1000
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;

      allow update, delete: if request.auth != null;
    }

    // Menu items: public can read (so the menu page can render them),
    // only a logged-in admin can add/edit/delete.
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Locations: public can read (locations, reserve & homepage pages render
    // these), only a logged-in admin can add/edit/delete branches.
    match /locations/{locationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Team roles: public can read (the about page renders these),
    // only a logged-in admin can add/edit/delete.
    match /team/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site-wide settings (social links, general WhatsApp number, homepage
    // stats): public can read, only a logged-in admin can write.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
